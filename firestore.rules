// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: {userId}
// Fields:
//   - uid: string (required)
//   - displayName: string (required)
//   - photoURL: string (optional)
//   - harmonyPoints: number (required)
//   - xp: number (required)
//   - level: number (required)
//   - lastActive: string (optional)
//
// Collection: buildings
// Document ID: {buildingId}
// Fields:
//   - id: string (required)
//   - ownerId: string (required)
//   - ownerName: string (optional)
//   - type: string (required, enum: ['oscillator', 'sequencer', 'sampler', 'fx', 'arpeggiator', 'global_fx', 'road'])
//   - x: number (required)
//   - y: number (required)
//   - color: string (optional)
//   - params: map (optional)
//   - level: number (required)
//   - createdAt: string (optional)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.ownerId;
    }
    
    function isAdmin() {
      return isAuthenticated() &&
             request.auth.token.email == "0mandrock1@gmail.com";
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) || isAdmin();
    }
    
    match /buildings/{buildingId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (request.resource.data.ownerId == request.auth.uid || isAdmin());
      allow update: if isAuthenticated() && (resource.data.ownerId == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }
  }
}
