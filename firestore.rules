// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: {userId}
// Fields:
//   - uid: string (required)
//   - displayName: string (required)
//   - photoURL: string (optional)
//   - harmonyPoints: number (required)
//   - xp: number (required)
//   - level: number (required)
//   - lastActive: string (optional)
//
// Collection: buildings
// Document ID: {buildingId}
// Fields:
//   - id: string (required)
//   - ownerId: string (required)
//   - ownerName: string (optional)
//   - type: string (required, enum: ['oscillator', 'sequencer', 'sampler', 'fx', 'arpeggiator', 'global_fx', 'road'])
//   - x: number (required)
//   - y: number (required)
//   - color: string (optional)
//   - params: map (optional)
//   - level: number (required)
//   - createdAt: string (optional)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.ownerId;
    }
    
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'harmonyPoints', 'xp', 'level']) &&
             data.uid is string &&
             data.displayName is string && data.displayName.size() < 100 &&
             data.harmonyPoints is number &&
             data.xp is number &&
             data.level is number;
    }
    
    function isValidBuilding(data) {
      return data.keys().hasAll(['id', 'ownerId', 'type', 'x', 'y', 'level']) &&
             data.id is string &&
             data.ownerId == request.auth.uid &&
             data.type in ['oscillator', 'sequencer', 'sampler', 'fx', 'arpeggiator', 'global_fx', 'road', 'power_plant', 'master_clock'] &&
             data.x is number && data.y is number &&
             data.level is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && 
                    request.resource.data.uid == resource.data.uid;
    }
    
    match /buildings/{buildingId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidBuilding(request.resource.data);
      allow update: if isDocOwner() && isValidBuilding(request.resource.data) &&
                    request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if isDocOwner();
    }
  }
}
